NEXT_PUBLIC_FORM_ENDPOINT=

# Optional: Calendly URL for the booking widget
NEXT_PUBLIC_CALENDLY_URL=

# Optional: Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
